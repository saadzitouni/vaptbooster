# =============================================================
# VAPTBOOSTER — environment template
# Copy to .env and fill in real values.
# =============================================================

# ---- Database ----
# The app connects as a LOW-PRIVILEGE role (vaptbooster_app) so Postgres
# Row-Level Security is enforced — a superuser/owner bypasses RLS even with
# FORCE, which would silently disable all tenant isolation. Create the role
# with scripts/init-db-roles.sql. Migrations + seed use the owner (DIRECT_URL).
POSTGRES_USER=vaptbooster
POSTGRES_PASSWORD=replace-with-strong-password
APP_DB_PASSWORD=replace-with-strong-app-password

# App runtime connection — low-privilege, RLS-enforced.
DATABASE_URL=postgresql://vaptbooster_app:replace-with-strong-app-password@localhost:5432/vaptbooster
# Owner connection — used ONLY by prisma migrate + seed (bypasses RLS).
DIRECT_URL=postgresql://vaptbooster:replace-with-strong-password@localhost:5432/vaptbooster

# ---- Redis ----
REDIS_PASSWORD=replace-with-strong-password
REDIS_URL=redis://default:replace-with-strong-password@localhost:6379

# ---- LiteLLM ----
LITELLM_MASTER_KEY=sk-master-replace-with-long-random-secret
LITELLM_BASE_URL=http://localhost:4000

# ---- LLM provider keys ----
# These never leave the LiteLLM container — the app + workers
# only ever see virtual keys, not these raw provider keys.
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ---- NextAuth ----
NEXTAUTH_SECRET=run-`openssl rand -base64 32`
NEXTAUTH_URL=http://localhost:3000

# ---- App ----
NODE_ENV=development
APP_URL=http://localhost:3000
ROOT_DOMAIN=vaptbooster.pwntrol.com

# ---- Email (Resend for invitations + notifications) ----
RESEND_API_KEY=re_...
EMAIL_FROM=ops@pwntrol.com

# ---- S3 (reports + evidence) ----
S3_BUCKET=vaptbooster-prod
S3_REGION=eu-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
