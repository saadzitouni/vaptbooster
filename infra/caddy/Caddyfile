# =============================================================
# VAPTBOOSTER reverse proxy.
# Terminates TLS and routes the apex + every tenant subdomain
# (acme.vaptbooster.pwntrol.com, etc.) to the Next.js app.
# ROOT_DOMAIN + ACME_EMAIL come from the environment.
# =============================================================

{
	email {$ACME_EMAIL}
	# For local testing without public DNS, uncomment to use Caddy's internal CA:
	# local_certs
}

# Apex — Caddy obtains a cert automatically via HTTP-01.
{$ROOT_DOMAIN} {
	encode zstd gzip
	reverse_proxy web:3000
}

# Tenant subdomains. A wildcard cert requires a DNS-01 challenge — add the
# Caddy DNS module for your provider and credentials, then uncomment the tls
# block. Until then this serves per-host certs on demand for known subdomains.
*.{$ROOT_DOMAIN} {
	encode zstd gzip
	reverse_proxy web:3000
	# tls {
	#   dns <provider> {env.DNS_API_TOKEN}
	# }
}
