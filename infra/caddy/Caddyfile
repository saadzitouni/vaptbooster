# =============================================================
# VAPTBOOSTER reverse proxy — HTTP on :8080 (no TLS).
#
# ⚠ This serves plain HTTP. Automatic HTTPS is OFF because Let's Encrypt
#   needs ports 80/443, which are unavailable on this host. For production
#   client logins, run on 80/443 with TLS instead (free port 80, then restore
#   the apex/*.ROOT_DOMAIN blocks with auto-HTTPS — see git history).
#
# The app routes tenants by Host header, so subdomains still work over :8080.
# =============================================================

{
	# No ACME on a plain-HTTP port — don't attempt certificates.
	auto_https off
}

:8080 {
	encode zstd gzip
	reverse_proxy web:3000
}
