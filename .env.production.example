# =============================================================
# VAPTBOOSTER — PRODUCTION environment.
# Copy to .env.production and fill in real values. The prod stack
# refuses to start if any required (marked) secret is unset.
#   docker compose -f docker-compose.prod.yml --env-file .env.production up -d --build
# =============================================================

# ---- Domain / TLS ----
ROOT_DOMAIN=vaptbooster.example.com     # required — apex; tenants live at *.ROOT_DOMAIN
ACME_EMAIL=ops@example.com              # for Let's Encrypt notifications

# ---- Database ----
POSTGRES_USER=vaptbooster
POSTGRES_PASSWORD=                      # required — strong random (owner)
APP_DB_PASSWORD=                        # required — strong random (low-priv app role)

# ---- Redis ----
REDIS_PASSWORD=                         # required — strong random

# ---- LiteLLM / providers ----
LITELLM_MASTER_KEY=                     # required — sk-master-<long random>
ANTHROPIC_API_KEY=                      # required — sk-ant-...
OPENAI_API_KEY=                         # optional

# ---- Auth ----
AUTH_SECRET=                            # required — `openssl rand -base64 32`

# ---- Behavior ----
SIMULATE_LLM=true                       # keep true until per-tenant virtual keys are provisioned, then set false
SEED_ON_INIT=false                      # true only for a first demo deploy (loads sample data)

# ---- Observability (optional) ----
SENTRY_DSN=                             # set + `npm i @sentry/nextjs` to enable error tracking
